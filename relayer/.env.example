# Relayer EOA private key (pays ETH gas for all sponsored transactions)
RELAYER_PRIVATE_KEY=0x...

# RPC endpoint for target chain (e.g., Sepolia)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Chain ID (Sepolia)
CHAIN_ID=11155111

# GasFlowDelegator contract address (EIP-7702 delegation target)
DELEGATOR_CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_DELEGATOR_ADDRESS

# GasFlowConfig contract address (global config + compensation gateway)
CONFIG_CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONFIG_ADDRESS

# GasFlowStakeVault proxy address (WETH vault)
STAKE_POOL_ADDRESS=0x_YOUR_DEPLOYED_STAKE_POOL_ADDRESS

# Comma-separated list of supported stablecoin addresses (must have Chainlink feed configured in Config)
SUPPORTED_FEE_TOKENS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Gas estimate safety margin in basis points, 12000 = 120%
GAS_ESTIMATE_MARGIN_BPS=12000

# maxFeeAmount buffer in basis points, 11000 = 110% (10% extra for price staleness)
FEE_AMOUNT_MARGIN_BPS=11000

# Server port
PORT=3000

# Optional API key required for POST /api/v1/submit and /api/v1/estimate
# Leave unset to disable authentication (not recommended for production)
RELAYER_API_KEY=change-me-in-production

# Maximum request body size in bytes (default 1 MiB)
MAX_BODY_SIZE=1048576

# Per-IP rate limiting window and max requests (default 100 req / 60 s)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Minimum ETH balance threshold before auto-refill (in wei)
MIN_RELAYER_BALANCE=100000000000000000

# Gas settings
MAX_FEE_PER_GAS_MULTIPLIER=3
PRIORITY_FEE=1000000000

# Simulation settings
MAX_BATCH_SIZE=10
SIMULATION_TIMEOUT_MS=30000

# ── 测试脚本用（scripts/test-submit.mjs）──
# 测试用户的私钥（和 relayer 的私钥不同，是发起赞助交易的用户 EOA）
TEST_USER_PRIVATE_KEY=0xYOUR_TEST_USER_PRIVATE_KEY
